# VentureOS runs fully with realistic mock data and NO keys.
# Add keys only to turn simulated actions into real ones.

# --- AI provider (optional) ---
# AI_PROVIDER selects the engine: "mock" (default), "anthropic", or "openai".
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Stripe (optional) ---
# With a secret key, the agent mints a real Stripe Payment Link.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- App ---
# Base URL used for absolute links and Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
